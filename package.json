{
  "name": "amazon-project",
  "version": "1.0.0",
  "description": "Amazon Relay order scraper and web interface",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "scrape": "node script.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docker:build": "docker build -t amazon-project:latest .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env -v $(pwd)/auth.json:/usr/src/app/auth.json:ro amazon-project:latest",
    "docker:compose:up": "docker compose up -d --build",
    "docker:compose:down": "docker compose down"
  },
